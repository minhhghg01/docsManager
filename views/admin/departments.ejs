<%- include('../partials/header') %>
<div class="flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <a href="/admin/dashboard" class="inline-flex items-center gap-1 text-sm text-brand-600 transition-all hover:text-brand-800 hover:underline">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Quản trị
    </a>
    <h1 class="text-2xl font-bold text-slate-800">Khoa / phòng</h1>
  </div>
  <div class="flex flex-wrap items-center gap-3">
    <%- include('../partials/pagination', { pg }) %>
  </div>
</div>
<% if (error) { %>
  <p class="mt-3 rounded-md bg-red-50 px-3 py-2 text-sm text-red-800"><%= error %></p>
<% } %>
<form method="post" action="/admin/departments" class="mt-6 flex flex-wrap items-end gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
  <div class="grow">
    <label class="block text-sm font-medium text-slate-700">Tên khoa/phòng mới</label>
    <input name="name" required class="mt-1 w-full max-w-md rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" placeholder="Ví dụ: Phòng Hành chính" />
  </div>
  <button type="submit" class="inline-flex items-center gap-1.5 rounded-md bg-brand-600 px-4 py-2 font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-md">
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
    Thêm
  </button>
</form>
<ul class="mt-8 divide-y divide-slate-200 rounded-xl border border-slate-200 bg-white shadow-sm">
  <% departments.forEach(function (d) { %>
    <li class="flex flex-wrap items-center justify-between gap-3 px-4 py-3 transition-all hover:bg-slate-50">
      <form method="post" action="/admin/departments/<%= d.id %>/edit" class="flex flex-wrap items-center gap-2">
        <input name="name" value="<%= d.name %>" class="rounded-md border border-slate-300 px-2 py-1 text-sm transition-all focus:border-brand-500 focus:ring-1 focus:ring-brand-500" />
        <button type="submit" class="rounded bg-slate-200 px-2 py-1 text-sm transition-all hover:bg-slate-300">Lưu</button>
      </form>
      <form method="post" action="/admin/departments/<%= d.id %>/delete" onsubmit="return confirm('Xóa khoa này?');">
        <button type="submit" class="text-sm text-red-600 transition-all hover:text-red-800 hover:underline">Xóa</button>
      </form>
    </li>
  <% }); %>
</ul>
<%- include('../partials/footer') %>
