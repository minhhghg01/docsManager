<%- include('../partials/header') %>
<div class="grid grid-cols-[auto_1fr_auto] items-center gap-3">
  <div class="flex items-center gap-2">
    <a href="/admin/dashboard" class="rounded p-1.5 text-brand-600 transition-all hover:bg-brand-50 hover:text-brand-800" title="Quản trị">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
    </a>
    <h1 class="text-2xl font-bold text-slate-800">Khoa / phòng</h1>
  </div>
  <div class="flex justify-center">
    <%- include('../partials/pagination', { pg, part: 'nav' }) %>
  </div>
  <div class="flex items-center gap-3">
    <%- include('../partials/pagination', { pg, part: 'info' }) %>
  </div>
</div>
<% if (error) { %>
  <p class="mt-3 rounded-md bg-red-50 px-3 py-2 text-sm text-red-800"><%= error %></p>
<% } %>
<form method="post" action="/admin/departments" class="mt-6 flex flex-wrap items-end gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
  <div class="grow">
    <label class="block text-sm font-medium text-slate-700">Tên khoa/phòng mới</label>
    <input name="name" required class="mt-1 w-full max-w-md rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" placeholder="Ví dụ: Phòng Hành chính" />
  </div>
  <button type="submit" class="inline-flex items-center gap-1.5 rounded-md bg-brand-600 px-4 py-2 font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-md">
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
    Thêm
  </button>
</form>
<ul class="mt-8 divide-y divide-slate-200 rounded-xl border border-slate-200 bg-white shadow-sm">
  <% departments.forEach(function (d) { %>
    <li class="flex flex-wrap items-center justify-between gap-3 px-4 py-3 transition-all hover:bg-slate-50">
      <form method="post" action="/admin/departments/<%= d.id %>/edit" class="flex flex-wrap items-center gap-2">
        <input name="name" value="<%= d.name %>" class="rounded-md border border-slate-300 px-2 py-1 text-sm transition-all focus:border-brand-500 focus:ring-1 focus:ring-brand-500" />
        <button type="submit" class="rounded p-1.5 text-slate-400 transition-all hover:bg-emerald-50 hover:text-emerald-600" title="Lưu">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
        </button>
      </form>
      <form method="post" action="/admin/departments/<%= d.id %>/delete" onsubmit="return confirm('Xóa khoa này?');">
        <button type="submit" class="rounded p-1.5 text-slate-400 transition-all hover:bg-red-50 hover:text-red-600" title="Xóa">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
        </button>
      </form>
    </li>
  <% }); %>
</ul>
<%- include('../partials/footer') %>
