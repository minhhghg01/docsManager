<%- include('../partials/header') %>
<div class="flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <a href="/admin/dashboard" class="inline-flex items-center gap-1 text-sm text-brand-600 transition-all hover:text-brand-800 hover:underline">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Quản trị
    </a>
    <h1 class="text-2xl font-bold text-slate-800">Tài khoản</h1>
  </div>
  <div class="flex flex-wrap items-center gap-3">
    <%- include('../partials/pagination', { pg }) %>
  </div>
</div>
<% if (error) { %>
  <p class="mt-3 rounded-md bg-red-50 px-3 py-2 text-sm text-red-800"><%= error %></p>
<% } %>
<div class="mt-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="font-semibold text-slate-800">Tạo tài khoản</h2>
  <form method="post" action="/admin/users" class="mt-4 grid gap-4 sm:grid-cols-2">
    <div>
      <label class="block text-sm font-medium text-slate-700">Username</label>
      <input name="username" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700">Mật khẩu</label>
      <input type="password" name="password" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700">Vai trò</label>
      <select name="role" id="roleSel" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:ring-1 focus:ring-brand-500">
        <option value="khoa">Khoa/phòng (1 acc chung)</option>
        <option value="admin">Admin</option>
      </select>
    </div>
    <div id="khoaWrap">
      <label class="block text-sm font-medium text-slate-700">Khoa/phòng</label>
      <select name="khoa_id" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:ring-1 focus:ring-brand-500">
        <option value="">— Chọn —</option>
        <% departments.forEach(function (d) { %>
          <option value="<%= d.id %>"><%= d.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="sm:col-span-2">
      <button type="submit" class="rounded-md bg-brand-600 px-4 py-2 font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-md">Tạo</button>
    </div>
  </form>
</div>
<ul class="mt-8 divide-y divide-slate-200 rounded-xl border border-slate-200 bg-white shadow-sm">
  <% users.forEach(function (u) { %>
    <li class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 transition-all hover:bg-slate-50">
      <div>
        <span class="font-medium"><%= u.username %></span>
        <span class="ml-2 rounded bg-slate-100 px-2 py-0.5 text-xs text-slate-700"><%= u.role === 'admin' ? 'Admin' : 'Khoa' %></span>
        <% if (u.khoa_name) { %><span class="ml-2 text-sm text-slate-500"><%= u.khoa_name %></span><% } %>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <form method="post" action="/admin/users/<%= u.id %>/password" class="flex items-center gap-1">
          <input type="password" name="password" placeholder="Mật khẩu mới" class="w-36 rounded border border-slate-300 px-2 py-1 text-sm transition-all focus:border-brand-500 focus:ring-1 focus:ring-brand-500" />
          <button type="submit" class="rounded p-1.5 text-slate-400 transition-all hover:bg-emerald-50 hover:text-emerald-600" title="Đổi mật khẩu">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
          </button>
        </form>
        <% if (u.id !== user.id) { %>
          <form method="post" action="/admin/users/<%= u.id %>/delete" onsubmit="return confirm('Xóa user này?');">
            <button type="submit" class="rounded p-1.5 text-slate-400 transition-all hover:bg-red-50 hover:text-red-600" title="Xóa">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
            </button>
          </form>
        <% } %>
      </div>
    </li>
  <% }); %>
</ul>
<script>
  (function () {
    var sel = document.getElementById('roleSel');
    var wrap = document.getElementById('khoaWrap');
    function sync() {
      wrap.style.display = sel.value === 'admin' ? 'none' : 'block';
    }
    sel.addEventListener('change', sync);
    sync();
  })();
</script>
<%- include('../partials/footer') %>
