<%- include('../partials/header') %>
<div class="flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <a href="/admin/dashboard" class="inline-flex items-center gap-1 text-sm text-brand-600 transition-all hover:text-brand-800 hover:underline">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Quản trị
    </a>
    <h1 class="text-2xl font-bold text-slate-800">Tài liệu</h1>
  </div>
  <div class="flex flex-wrap items-center gap-3">
    <%- include('../partials/pagination', { pg }) %>
    <a href="/admin/documents/new" class="inline-flex items-center gap-1.5 rounded-md bg-brand-600 px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-md">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      Thêm
    </a>
  </div>
</div>
<ul class="mt-8 divide-y divide-slate-200 rounded-xl border border-slate-200 bg-white shadow-sm">
  <% if (!docs.length) { %>
    <li class="px-4 py-8 text-center text-slate-500">Chưa có tài liệu.</li>
  <% } %>
  <% docs.forEach(function (d) { %>
    <li class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 cursor-pointer transition-all hover:bg-slate-50" onclick="if(!event.target.closest('a,button,form'))location.href='/docs/<%= d.id %>'">
      <div>
        <span class="font-medium text-brand-700"><%= d.title %></span>
        <p class="text-sm text-slate-500">Nguồn: <%= d.source_label %>
          <% if (d.is_public) { %><span class="ml-2 text-emerald-700">[công khai]</span><% } %>
        </p>
        <% if (d.tags && d.tags.length) { %>
          <div class="mt-1 flex flex-wrap gap-1">
            <% d.tags.forEach(function (t) { %>
              <span class="rounded-full bg-brand-100 px-2 py-0.5 text-xs text-brand-700"><%= t %></span>
            <% }); %>
          </div>
        <% } %>
      </div>
      <div class="flex items-center gap-2">
        <a href="/admin/documents/<%= d.id %>/edit" class="rounded p-1.5 text-slate-400 transition-all hover:bg-slate-100 hover:text-brand-600" title="Sửa">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125"/></svg>
        </a>
        <form method="post" action="/admin/documents/<%= d.id %>/delete" class="inline" onsubmit="return confirm('Xóa tài liệu này?');">
          <button type="submit" class="rounded p-1.5 text-slate-400 transition-all hover:bg-red-50 hover:text-red-600" title="Xóa">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
          </button>
        </form>
      </div>
    </li>
  <% }); %>
</ul>
<%- include('../partials/footer') %>
