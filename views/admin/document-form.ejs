<%- include('../partials/header') %>
<h1 class="text-2xl font-bold text-slate-800"><%= doc ? 'Sửa tài liệu' : 'Thêm tài liệu' %></h1>
<% if (error) { %>
  <p class="mt-3 rounded-md bg-red-50 px-3 py-2 text-sm text-red-800"><%= error %></p>
<% } %>
<form
  method="post"
  action="<%= doc ? '/admin/documents/' + doc.id : '/admin/documents' %>"
  enctype="multipart/form-data"
  class="mt-6 space-y-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm"
>
  <div>
    <label class="block text-sm font-medium text-slate-700">Tiêu đề</label>
    <input name="title" required value="<%= doc ? doc.title : '' %>" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700">Nguồn</label>
    <input name="source_label" required value="<%= doc ? doc.source_label : '' %>" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" placeholder="Ví dụ: Phòng KHCN" />
  </div>
  <div class="flex items-center gap-2">
    <input type="checkbox" name="is_public" value="1" id="pub" <%= doc && doc.is_public ? 'checked' : '' %> class="h-4 w-4 rounded border-slate-300" />
    <label for="pub" class="text-sm text-slate-700">Công khai</label>
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700">Thuộc khoa/phòng</label>
    <select name="owner_khoa_id" class="mt-1 w-full max-w-md rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:ring-1 focus:ring-brand-500">
      <option value="">— Không gán —</option>
      <% departments.forEach(function (k) { %>
        <option value="<%= k.id %>" <%= doc && doc.owner_khoa_id === k.id ? 'selected' : '' %>><%= k.name %></option>
      <% }); %>
    </select>
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700">Chia sẻ xem cho các khoa khác</label>
    <p class="text-xs text-slate-500">Chọn thêm khoa được phép xem (ngoài khoa sở hữu và tài liệu công khai).</p>
    <div class="mt-2 max-h-40 space-y-1 overflow-y-auto rounded-md border border-slate-200 p-2">
      <% departments.forEach(function (k) { %>
        <% var checked = doc && doc.shared_khoa_ids && doc.shared_khoa_ids.indexOf(k.id) !== -1; %>
        <label class="flex items-center gap-2 text-sm">
          <input type="checkbox" name="shared_khoa_ids" value="<%= k.id %>" <%= checked ? 'checked' : '' %> />
          <%= k.name %>
        </label>
      <% }); %>
    </div>
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700">Tags (phân cách bằng dấu phẩy)</label>
    <input name="tags" value="<%= doc && doc.tags ? doc.tags.join(', ') : '' %>" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 transition-all focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" placeholder="Ví dụ: quy trình, biểu mẫu, hướng dẫn" />
  </div>
  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class="block text-sm font-medium text-slate-700">File <%= doc ? '(để trống nếu giữ file cũ)' : '' %></label>
      <input type="file" name="file" <%= doc ? '' : 'required' %> class="mt-1 w-full text-sm" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.odt,.ods,.odp" />
      <% if (doc) { %>
        <p class="mt-1 text-xs text-slate-500">Đang có: <%= doc.original_filename %></p>
      <% } %>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700">Ảnh banner (tùy chọn)</label>
      <input type="file" name="banner" class="mt-1 w-full text-sm" accept="image/*" />
      <% if (doc && doc.banner_filename) { %>
        <p class="mt-1 text-xs text-slate-500">Đang có banner. Để trống giữ ảnh cũ.</p>
      <% } else { %>
        <p class="mt-1 text-xs text-slate-400">Không chọn → hiển thị icon định dạng file.</p>
      <% } %>
    </div>
  </div>
  <div class="flex gap-3">
    <button type="submit" class="rounded-md bg-brand-600 px-4 py-2 font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-md">Lưu</button>
    <a href="/admin/documents" class="rounded-md border border-slate-300 px-4 py-2 font-medium text-slate-700 transition-all hover:bg-slate-100">Hủy</a>
  </div>
</form>
<%- include('../partials/footer') %>
