<%- include('../partials/header') %>
<h1 class="text-2xl font-bold text-slate-800 dark:text-white">Bảng điều khiển</h1>
<div class="mt-8 grid gap-4 sm:grid-cols-3">
  <a href="/admin/documents" class="hover-lift rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 shadow-sm transition-all hover:border-brand-400 dark:hover:border-brand-500">
    <p class="text-sm text-slate-500 dark:text-slate-400">Tài liệu</p>
    <p class="text-3xl font-bold text-brand-700 dark:text-brand-500"><%= docCount %></p>
  </a>
  <a href="/admin/users" class="hover-lift rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 shadow-sm transition-all hover:border-brand-400 dark:hover:border-brand-500">
    <p class="text-sm text-slate-500 dark:text-slate-400">Tài khoản</p>
    <p class="text-3xl font-bold text-brand-700 dark:text-brand-500"><%= userCount %></p>
  </a>
  <a href="/admin/departments" class="hover-lift rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 shadow-sm transition-all hover:border-brand-400 dark:hover:border-brand-500">
    <p class="text-sm text-slate-500 dark:text-slate-400">Khoa / phòng</p>
    <p class="text-3xl font-bold text-brand-700 dark:text-brand-500"><%= deptCount %></p>
  </a>
</div>
<ul class="mt-8 flex flex-wrap gap-3 text-sm">
  <li><a href="/admin/documents/new" class="text-brand-600 transition-all hover:text-brand-800 hover:underline">Thêm tài liệu</a></li>
  <li><a href="/docs" class="text-brand-600 transition-all hover:text-brand-800 hover:underline">Xem site</a></li>
</ul>
<%- include('../partials/footer') %>
