<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title><%= doc.title %></title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.9.155/pdf.min.mjs" type="module"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}

/* layout */
.viewer{display:flex;height:100vh;background:#2a2a2e}
.sidebar{width:200px;background:#38383d;overflow-y:auto;padding:12px 8px;flex-shrink:0;
  border-right:1px solid #1a1a1e;display:flex;flex-direction:column;gap:8px}
.sidebar.hidden{display:none}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}

/* toolbar */
.toolbar{display:flex;align-items:center;gap:8px;padding:6px 12px;background:#38383d;
  border-bottom:1px solid #1a1a1e;flex-shrink:0;flex-wrap:wrap;min-height:44px}
.toolbar .group{display:flex;align-items:center;gap:6px}
.toolbar .sep{width:1px;height:24px;background:#555;margin:0 4px}
.toolbar button,.toolbar select{background:#4a4a4f;color:#fff;border:none;border-radius:4px;
  padding:6px 10px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:4px}
.toolbar button:hover{background:#5a5a5f}
.toolbar button.active{background:#0a84ff}
.toolbar input[type="number"]{width:50px;background:#4a4a4f;color:#fff;border:none;
  border-radius:4px;padding:6px 8px;font-size:13px;text-align:center}
.toolbar .page-info{color:#ccc;font-size:13px;white-space:nowrap}
.toolbar .title{color:#fff;font-size:13px;margin-left:auto;overflow:hidden;text-overflow:ellipsis;
  white-space:nowrap;max-width:300px}
.toolbar select{appearance:auto}

/* page container */
.page-container{flex:1;overflow:auto;padding:16px;display:flex;flex-direction:column;
  align-items:center;gap:12px;background:#404040}
.page-wrapper{box-shadow:0 2px 10px rgba(0,0,0,.4);background:#fff;position:relative}
.page-wrapper canvas{display:block}

/* thumbnails */
.thumb{cursor:pointer;border:2px solid transparent;border-radius:4px;overflow:hidden;
  transition:border-color .15s}
.thumb:hover{border-color:#888}
.thumb.active{border-color:#0a84ff}
.thumb canvas{display:block;width:100%}
.thumb-label{text-align:center;color:#aaa;font-size:11px;padding:4px 0}

/* icons via unicode */
.icon{font-size:16px;line-height:1}
</style>
</head>
<body>
<div class="viewer">
  <!-- Sidebar thumbnails -->
  <div class="sidebar" id="sidebar"></div>

  <div class="main">
    <!-- Toolbar -->
    <div class="toolbar">
      <div class="group">
        <button id="toggleSidebar" title="Sidebar"><span class="icon">&#9776;</span></button>
      </div>
      <div class="sep"></div>
      <div class="group">
        <button id="prevPage" title="Trang trước"><span class="icon">&#9650;</span></button>
        <input type="number" id="pageNum" value="1" min="1"/>
        <span class="page-info">/ <span id="pageCount">-</span></span>
        <button id="nextPage" title="Trang sau"><span class="icon">&#9660;</span></button>
      </div>
      <div class="sep"></div>
      <div class="group">
        <button id="zoomOut" title="Thu nhỏ"><span class="icon">&#8722;</span></button>
        <select id="zoomSelect">
          <option value="0.5">50%</option>
          <option value="0.75">75%</option>
          <option value="1" selected>100%</option>
          <option value="1.25">125%</option>
          <option value="1.5">150%</option>
          <option value="2">200%</option>
          <option value="fit">Vừa trang</option>
          <option value="width">Vừa chiều ngang</option>
        </select>
        <button id="zoomIn" title="Phóng to"><span class="icon">&#43;</span></button>
      </div>
      <div class="sep"></div>
      <div class="group">
        <button id="printBtn" title="In"><span class="icon">&#128424;</span></button>
        <a href="/docs/<%= doc.id %>/download" style="text-decoration:none">
          <button title="Tải xuống"><span class="icon">&#8615;</span></button>
        </a>
      </div>
      <span class="title"><%= doc.original_filename %></span>
    </div>

    <!-- Pages -->
    <div class="page-container" id="pageContainer"></div>
  </div>
</div>

<script type="module">
const url = '/docs/<%= doc.id %>/view/raw';
const pdfjsLib = await import('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.9.155/pdf.min.mjs');
pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.9.155/pdf.worker.min.mjs';

const container = document.getElementById('pageContainer');
const sidebar = document.getElementById('sidebar');
const pageNumInput = document.getElementById('pageNum');
const pageCountSpan = document.getElementById('pageCount');
const zoomSelect = document.getElementById('zoomSelect');

let pdfDoc = null;
let currentScale = 1;
let pages = [];
let thumbs = [];
let rendering = false;

const pdf = await pdfjsLib.getDocument(url).promise;
pdfDoc = pdf;
pageCountSpan.textContent = pdf.numPages;
pageNumInput.max = pdf.numPages;

async function renderPage(num, scale) {
  const page = await pdfDoc.getPage(num);
  const viewport = page.getViewport({ scale });
  const canvas = document.createElement('canvas');
  canvas.width = viewport.width;
  canvas.height = viewport.height;
  const ctx = canvas.getContext('2d');
  await page.render({ canvasContext: ctx, viewport }).promise;
  return canvas;
}

async function renderThumb(num) {
  const page = await pdfDoc.getPage(num);
  const vp = page.getViewport({ scale: 0.3 });
  const canvas = document.createElement('canvas');
  canvas.width = vp.width;
  canvas.height = vp.height;
  const ctx = canvas.getContext('2d');
  await page.render({ canvasContext: ctx, viewport: vp }).promise;
  return canvas;
}

function getScale() {
  const val = zoomSelect.value;
  if (val === 'fit' || val === 'width') return val;
  return parseFloat(val);
}

async function renderAll() {
  if (rendering) return;
  rendering = true;
  container.innerHTML = '';
  pages = [];

  const firstPage = await pdfDoc.getPage(1);
  let scale = getScale();
  if (scale === 'fit') {
    const vp = firstPage.getViewport({ scale: 1 });
    const ch = container.clientHeight - 32;
    scale = ch / vp.height;
  } else if (scale === 'width') {
    const vp = firstPage.getViewport({ scale: 1 });
    const cw = container.clientWidth - 48;
    scale = cw / vp.width;
  }
  currentScale = scale;

  for (let i = 1; i <= pdfDoc.numPages; i++) {
    const wrapper = document.createElement('div');
    wrapper.className = 'page-wrapper';
    wrapper.dataset.page = i;
    const canvas = await renderPage(i, currentScale);
    wrapper.appendChild(canvas);
    container.appendChild(wrapper);
    pages.push(wrapper);
  }
  rendering = false;
}

async function renderThumbnails() {
  sidebar.innerHTML = '';
  thumbs = [];
  for (let i = 1; i <= pdfDoc.numPages; i++) {
    const div = document.createElement('div');
    div.className = 'thumb' + (i === 1 ? ' active' : '');
    div.dataset.page = i;
    const canvas = await renderThumb(i);
    div.appendChild(canvas);
    const label = document.createElement('div');
    label.className = 'thumb-label';
    label.textContent = i;
    div.appendChild(label);
    div.addEventListener('click', () => scrollToPage(i));
    sidebar.appendChild(div);
    thumbs.push(div);
  }
}

function scrollToPage(num) {
  if (pages[num - 1]) {
    pages[num - 1].scrollIntoView({ behavior: 'smooth', block: 'start' });
    setActivePage(num);
  }
}

function setActivePage(num) {
  pageNumInput.value = num;
  thumbs.forEach((t, i) => t.classList.toggle('active', i === num - 1));
}

container.addEventListener('scroll', () => {
  const ct = container.scrollTop + 100;
  for (let i = pages.length - 1; i >= 0; i--) {
    if (pages[i].offsetTop <= ct) {
      setActivePage(i + 1);
      break;
    }
  }
});

document.getElementById('prevPage').addEventListener('click', () => {
  const cur = parseInt(pageNumInput.value);
  if (cur > 1) scrollToPage(cur - 1);
});
document.getElementById('nextPage').addEventListener('click', () => {
  const cur = parseInt(pageNumInput.value);
  if (cur < pdfDoc.numPages) scrollToPage(cur + 1);
});
pageNumInput.addEventListener('change', () => {
  let v = parseInt(pageNumInput.value);
  if (v < 1) v = 1;
  if (v > pdfDoc.numPages) v = pdfDoc.numPages;
  scrollToPage(v);
});

zoomSelect.addEventListener('change', () => renderAll());
document.getElementById('zoomOut').addEventListener('click', () => {
  const vals = [0.5, 0.75, 1, 1.25, 1.5, 2];
  const cur = currentScale;
  for (let i = vals.length - 1; i >= 0; i--) {
    if (vals[i] < cur - 0.01) { zoomSelect.value = vals[i]; renderAll(); return; }
  }
});
document.getElementById('zoomIn').addEventListener('click', () => {
  const vals = [0.5, 0.75, 1, 1.25, 1.5, 2];
  const cur = currentScale;
  for (const v of vals) {
    if (v > cur + 0.01) { zoomSelect.value = v; renderAll(); return; }
  }
});

document.getElementById('toggleSidebar').addEventListener('click', () => {
  sidebar.classList.toggle('hidden');
});

document.getElementById('printBtn').addEventListener('click', () => window.print());

await renderAll();
await renderThumbnails();
</script>
</body>
</html>
