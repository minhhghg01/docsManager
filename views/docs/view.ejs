<%- include('../partials/header') %>
<div class="mb-4 flex flex-wrap items-center justify-between gap-3">
  <div>
    <h1 class="text-2xl font-bold text-slate-800"><%= doc.title %></h1>
    <p class="text-sm text-slate-500">Nguồn: <%= doc.source_label %> · <%= doc.original_filename %></p>
    <% if (doc.tags && doc.tags.length) { %>
      <div class="mt-1.5 flex flex-wrap gap-1">
        <% doc.tags.forEach(function (t) { %>
          <a href="/docs?tags=<%= encodeURIComponent(t) %>" class="rounded-full bg-brand-50 px-2 py-0.5 text-xs text-brand-600 transition-all hover:bg-brand-100"><%= t %></a>
        <% }); %>
      </div>
    <% } %>
  </div>
  <div class="flex gap-2">
    <a href="/docs/<%= doc.id %>/download" class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition-all hover:bg-slate-100 hover:shadow-sm">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
      Tải file gốc
    </a>
    <a href="/docs" class="inline-flex items-center gap-1.5 rounded-md bg-slate-200 px-3 py-2 text-sm font-medium text-slate-800 transition-all hover:bg-slate-300">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Quay lại
    </a>
  </div>
</div>
<div class="overflow-hidden rounded-xl border border-slate-200 bg-slate-100 shadow-inner">
  <iframe
    title="Xem tài liệu"
    src="/docs/<%= doc.id %>/view"
    class="h-[75vh] w-full bg-white"
  ></iframe>
</div>
<p class="mt-3 text-xs text-slate-500">
  File Word/Excel/PowerPoint được chuyển HTML để xem trực tiếp trên trình duyệt. PDF hiển thị trực tiếp.
</p>
<% if (user && user.role === 'admin') { %>
  <p class="mt-2"><a href="/admin/documents/<%= doc.id %>/edit" class="text-sm font-medium text-brand-600 transition-all hover:text-brand-800 hover:underline">Sửa / chia sẻ (quản trị)</a></p>
<% } %>
<%- include('../partials/footer') %>
