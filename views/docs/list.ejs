<%- include('../partials/header') %>
<div class="grid grid-cols-[auto_1fr_auto] items-center gap-3">
  <h1 class="text-2xl font-bold text-slate-800">Tài liệu</h1>
  <div class="flex justify-center">
    <%- include('../partials/pagination', { pg: pagination, part: 'nav' }) %>
  </div>
  <div class="flex items-center gap-3">
    <%- include('../partials/pagination', { pg: pagination, part: 'info' }) %>
    <% if (isAdmin) { %>
      <a href="/admin/documents/new" class="inline-flex items-center gap-1.5 rounded-md bg-brand-600 px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-md">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Thêm tài liệu
      </a>
    <% } %>
  </div>
</div>
<p class="mt-2 text-sm text-slate-600">
  <% if (!user) { %>
    Bạn đang xem tài liệu <strong>công khai</strong>. Đăng nhập để xem thêm tài liệu theo khoa/phòng.
  <% } else if (user.role === 'admin') { %>
    Bạn là quản trị — hiển thị mọi tài liệu.
  <% } else { %>
    Hiển thị tài liệu công khai, của khoa bạn và được chia sẻ.
  <% } %>
</p>

<!-- Search & Filter -->
<form id="filterForm" method="get" action="/docs" class="mt-6 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
  <input type="hidden" name="tags" id="tagsInput" value="<%= filters.tags.join(',') %>" />
  <input type="hidden" name="pub" id="pubInput" value="<%= filters.pub %>" />
  <input type="hidden" name="page" value="1" />
  <div class="flex flex-col gap-3 sm:flex-row">
    <div class="flex-1">
      <input type="text" name="q" id="searchInput" value="<%= filters.search %>" placeholder="Tìm theo tiêu đề hoặc nguồn..." autocomplete="off" class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm transition-all focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
    </div>
    <div>
      <select name="dept" id="deptSelect" class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm transition-all focus:border-brand-500 focus:ring-1 focus:ring-brand-500 sm:w-52">
        <option value="">— Tất cả khoa/phòng —</option>
        <% departments.forEach(function (d) { %>
          <option value="<%= d.id %>" <%= String(filters.deptId) === String(d.id) ? 'selected' : '' %>><%= d.name %><% if (deptCounts[d.id]) { %> (<%= deptCounts[d.id] %>)<% } %></option>
        <% }); %>
      </select>
    </div>
    <div class="flex gap-2">
      <noscript><button type="submit" class="rounded-md bg-brand-600 px-4 py-2 text-sm font-semibold text-white">Tìm</button></noscript>
      <% if (filters.search || filters.tags.length || filters.deptId || filters.pub) { %>
        <a href="/docs" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 transition-all hover:bg-slate-100">Xóa lọc</a>
      <% } %>
    </div>
  </div>
  <% if (filters.search || filters.tags.length || filters.deptId || filters.pub) { %>
    <p class="mt-2 text-xs text-slate-500">
      Tìm thấy <strong><%= pagination.totalCount %></strong> tài liệu
      <% if (filters.search) { %> · từ khóa "<%= filters.search %>"<% } %>
      <% if (filters.tags.length) { %> · tags: <%= filters.tags.join(', ') %><% } %>
      <% if (filters.deptId) { %><% var deptName = departments.find(function(d){ return String(d.id) === String(filters.deptId); }); %><% if (deptName) { %> · khoa "<%= deptName.name %>"<% } %><% } %>
      <% if (filters.pub === '1') { %> · công khai<% } else if (filters.pub === '0') { %> · nội bộ<% } %>
    </p>
  <% } %>
</form>

<!-- Tag cloud + pub filter (multi-select style) -->
<div class="mt-4 flex flex-wrap gap-2" id="tagCloud">
  <% if (user) { %>
    <button type="button" data-pub="1" class="pub-btn rounded-full border px-3 py-1 text-xs font-medium transition-all hover:border-emerald-400 hover:bg-emerald-50 hover:text-emerald-700 <%= filters.pub === '1' ? 'border-emerald-500 bg-emerald-100 text-emerald-700' : 'border-slate-200 bg-white text-slate-600' %>">Công khai</button>
    <button type="button" data-pub="0" class="pub-btn rounded-full border px-3 py-1 text-xs font-medium transition-all hover:border-amber-400 hover:bg-amber-50 hover:text-amber-700 <%= filters.pub === '0' ? 'border-amber-500 bg-amber-100 text-amber-700' : 'border-slate-200 bg-white text-slate-600' %>">Nội bộ</button>
    <% if (allTags.length) { %><span class="self-center text-slate-300">|</span><% } %>
  <% } %>
  <% allTags.forEach(function (t) { %>
    <% var isSelected = filters.tags.indexOf(t) !== -1; %>
    <button type="button" data-tag="<%= t %>" class="tag-btn rounded-full border px-3 py-1 text-xs font-medium transition-all hover:border-brand-400 hover:bg-brand-50 hover:text-brand-700 <%= isSelected ? 'border-brand-500 bg-brand-100 text-brand-700' : 'border-slate-200 bg-white text-slate-600' %>">
      <%= t %> <span class="opacity-40">(<%= tagCounts[t] || 0 %>)</span>
    </button>
  <% }); %>
</div>

<!-- Documents list -->
<ul class="mt-6 divide-y divide-slate-200 rounded-xl border border-slate-200 bg-white shadow-sm">
  <% if (!docs.length) { %>
    <li class="px-4 py-8 text-center text-slate-500">Không có tài liệu phù hợp.</li>
  <% } %>
  <% docs.forEach(function (d) { %>
    <li class="group flex flex-wrap items-center justify-between gap-3 px-4 py-4 cursor-pointer transition-all hover:bg-slate-50" onclick="if(!event.target.closest('a,button,form'))location.href='/docs/<%= d.id %>'">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <a href="/docs/<%= d.id %>" class="font-medium text-brand-700 transition-all hover:text-brand-900 hover:underline"><%= d.title %></a>
          <% if (d.is_public) { %><span class="rounded bg-emerald-100 px-2 py-0.5 text-xs text-emerald-800">Công khai</span><% } %>
        </div>
        <p class="text-sm text-slate-500">Nguồn: <%= d.source_label %></p>
        <% if (d.tags && d.tags.length) { %>
          <div class="mt-1.5 flex flex-wrap gap-1">
            <% d.tags.forEach(function (t) { %>
              <button type="button" data-tag="<%= t %>" class="tag-btn rounded-full bg-brand-50 px-2 py-0.5 text-xs text-brand-600 transition-all hover:bg-brand-100"><%= t %></button>
            <% }); %>
          </div>
        <% } %>
      </div>
      <div class="flex items-center gap-1 opacity-60 transition-all group-hover:opacity-100">
        <a href="/docs/<%= d.id %>/download" class="rounded p-1.5 text-slate-400 transition-all hover:bg-slate-100 hover:text-slate-700" title="Tải file gốc">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
        </a>
      </div>
    </li>
  <% }); %>
</ul>

<script>
(function () {
  var timer, fetchCtrl;
  var currentPS = '<%= pagination.pageSize %>';

  function buildUrl() {
    var p = new URLSearchParams();
    var q = document.getElementById('searchInput').value.trim();
    var tags = document.getElementById('tagsInput').value;
    var dept = document.getElementById('deptSelect').value;
    var pub = document.getElementById('pubInput').value;
    if (q) p.set('q', q);
    if (tags) p.set('tags', tags);
    if (dept) p.set('dept', dept);
    if (pub) p.set('pub', pub);
    p.set('ps', currentPS);
    p.set('page', '1');
    return '/docs?' + p.toString();
  }

  function liveUpdate() {
    var searchInput = document.getElementById('searchInput');
    var cursorPos = searchInput.selectionStart;
    var searchVal = searchInput.value;
    var url = buildUrl();

    if (fetchCtrl) fetchCtrl.abort();
    fetchCtrl = new AbortController();

    history.replaceState(null, '', url);

    fetch(url, { signal: fetchCtrl.signal })
      .then(function (r) { return r.text(); })
      .then(function (html) {
        var parser = new DOMParser();
        var newDoc = parser.parseFromString(html, 'text/html');
        var newMain = newDoc.querySelector('main');
        if (!newMain) return;
        document.querySelector('main').innerHTML = newMain.innerHTML;
        initPage();
        var inp = document.getElementById('searchInput');
        if (inp) {
          inp.value = searchVal;
          inp.focus();
          inp.setSelectionRange(cursorPos, cursorPos);
        }
      })
      .catch(function (e) {
        if (e.name !== 'AbortError') location.href = url;
      });
  }

  function initPage() {
    var searchInput = document.getElementById('searchInput');
    var deptSelect = document.getElementById('deptSelect');
    var tagsInput = document.getElementById('tagsInput');
    var pubInput = document.getElementById('pubInput');

    searchInput.addEventListener('input', function () {
      clearTimeout(timer);
      timer = setTimeout(liveUpdate, 500);
    });

    deptSelect.addEventListener('change', liveUpdate);

    document.querySelectorAll('.tag-btn').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var tag = this.getAttribute('data-tag');
        var current = tagsInput.value ? tagsInput.value.split(',').filter(Boolean) : [];
        var idx = current.indexOf(tag);
        if (idx >= 0) current.splice(idx, 1);
        else current.push(tag);
        tagsInput.value = current.join(',');
        liveUpdate();
      });
    });

    document.querySelectorAll('.pub-btn').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var val = this.getAttribute('data-pub');
        pubInput.value = pubInput.value === val ? '' : val;
        liveUpdate();
      });
    });
  }

  initPage();
})();
</script>
<%- include('../partials/footer') %>
