<!-- AI Chat Panel - Cho phép mọi user đăng nhập -->
<% if (user) { %>

<!-- Floating button -->
<button id="ai-chat-toggle"
  onclick="toggleAiChat()"
  class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 text-white shadow-lg transition-all hover:scale-110 hover:shadow-xl active:scale-95"
  title="Trợ lý AI">
  <svg id="ai-chat-icon-open" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z"/>
  </svg>
  <svg id="ai-chat-icon-close" class="h-7 w-7 hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
  </svg>
</button>

<!-- Chat panel -->
<div id="ai-chat-panel"
  class="fixed bottom-24 right-6 z-50 hidden w-[calc(100vw-3rem)] sm:w-[400px] max-h-[600px] flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl"
  style="display:none;">

  <!-- Header -->
  <div class="flex items-center gap-3 bg-gradient-to-r from-indigo-600 to-purple-600 px-5 py-4">
    <div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/20">
      <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
      </svg>
    </div>
    <div>
      <h3 class="text-sm font-bold text-white">Trợ lý AI</h3>
      <p class="text-xs text-white/70">Hỏi đáp dựa trên tài liệu nội bộ</p>
    </div>
  </div>

  <!-- Messages -->
  <div id="ai-chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4" style="max-height:400px; min-height:200px;">
    <!-- Welcome message -->
    <div class="flex gap-3" id="ai-welcome-msg">
      <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-indigo-100">
        <span class="text-sm">🤖</span>
      </div>
      <div class="rounded-2xl rounded-tl-sm bg-slate-100 px-4 py-3 text-sm text-slate-700 max-w-[85%]">
        <div class="mb-2">Xin chào! Tôi là trợ lý AI. Hãy đặt câu hỏi về nội dung các tài liệu trong hệ thống, tôi sẽ tìm và trả lời cho bạn.</div>
        <button id="btn-tts-global-welcome" data-text="Xin chào! Tôi là trợ lý AI. Hãy đặt câu hỏi về nội dung các tài liệu trong hệ thống, tôi sẽ tìm và trả lời cho bạn." onclick="playGlobalTtSAudio(this.dataset.text, this.id)" class="inline-flex items-center gap-1 text-xs font-medium text-brand-600 bg-indigo-50 hover:bg-brand-100 px-2 py-1 rounded transition-colors" title="Đọc văn bản">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.5-.62-1.5-1.5v-4.5c0-.88.62-1.5 1.5-1.5h2.24Z"/></svg>
          Nghe đáp án
        </button>
      </div>
    </div>
  </div>

  <!-- Input -->
  <div class="border-t border-slate-200 bg-slate-50 p-4">
    <form id="ai-chat-form" onsubmit="sendAiChat(event)" class="flex gap-2">
      <input
        type="text"
        id="ai-chat-input"
        placeholder="Nhập câu hỏi..."
        autocomplete="off"
        class="flex-1 rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-700 placeholder-slate-400 transition-all focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-100"
      />
      <button type="submit" id="ai-chat-send"
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white transition-all hover:bg-indigo-700 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<style>
  @keyframes aiMsgIn {
    from { opacity:0; transform: translateY(8px); }
    to { opacity:1; transform:translateY(0); }
  }
  .ai-msg-animate { animation: aiMsgIn 0.3s ease-out; }

  @keyframes aiDot {
    0%, 80%, 100% { transform: scale(0.6); opacity:0.4; }
    40% { transform: scale(1); opacity:1; }
  }
  .ai-thinking-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #818cf8;
    animation: aiDot 1.2s infinite;
  }
  .ai-thinking-dot:nth-child(2) { animation-delay: 0.15s; }
  .ai-thinking-dot:nth-child(3) { animation-delay: 0.3s; }

  #ai-chat-panel {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  #ai-chat-panel.ai-panel-show {
    display: flex !important;
    opacity: 1;
    transform: translateY(0);
  }
  #ai-chat-panel.ai-panel-hide {
    opacity: 0;
    transform: translateY(10px);
  }
</style>

<script>
let aiChatOpen = false;

function toggleAiChat() {
  const panel = document.getElementById('ai-chat-panel');
  const iconOpen = document.getElementById('ai-chat-icon-open');
  const iconClose = document.getElementById('ai-chat-icon-close');

  aiChatOpen = !aiChatOpen;

  if (aiChatOpen) {
    panel.style.display = 'flex';
    requestAnimationFrame(() => panel.classList.add('ai-panel-show'));
    panel.classList.remove('ai-panel-hide');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    document.getElementById('ai-chat-input').focus();
  } else {
    panel.classList.remove('ai-panel-show');
    panel.classList.add('ai-panel-hide');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    setTimeout(() => { panel.style.display = 'none'; }, 200);
  }
}

function addChatMessage(role, content) {
  const container = document.getElementById('ai-chat-messages');

  const wrapper = document.createElement('div');
  wrapper.className = 'flex ai-msg-animate ' + (role === 'user' ? 'justify-end' : 'gap-3');

  if (role === 'user') {
    wrapper.innerHTML = `
      <div class="rounded-2xl rounded-tr-sm bg-indigo-600 px-4 py-3 text-sm text-white max-w-[85%]">
        ${escapeHtmlChat(content)}
      </div>`;
  } else {
    const cleanContent = escapeHtmlChat(content).replace(/"/g, '&quot;');
    const btnId = 'btn-tts-global-' + Date.now() + Math.floor(Math.random() * 1000);
    wrapper.innerHTML = `
      <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-indigo-100">
        <span class="text-sm">🤖</span>
      </div>
      <div class="rounded-2xl rounded-tl-sm bg-slate-100 px-4 py-3 text-sm text-slate-700 max-w-[85%]">
        <div class="mb-2">${formatAiAnswer(content)}</div>
        <button id="${btnId}" data-text="${cleanContent}" onclick="playGlobalTtSAudio(this.dataset.text, this.id)" class="inline-flex items-center gap-1 text-xs font-medium text-brand-600 bg-indigo-50 hover:bg-brand-100 px-2 py-1 rounded transition-colors" title="Đọc toàn bộ câu trả lời">
           <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.5-.62-1.5-1.5v-4.5c0-.88.62-1.5 1.5-1.5h2.24Z"/></svg>
           Nghe đáp án
         </button>
      </div>`;
  }

  container.appendChild(wrapper);
  container.scrollTop = container.scrollHeight;
  return wrapper;
}

function addThinkingIndicator() {
  const container = document.getElementById('ai-chat-messages');
  const wrapper = document.createElement('div');
  wrapper.className = 'flex gap-3 ai-msg-animate';
  wrapper.id = 'ai-thinking';
  wrapper.innerHTML = `
    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-indigo-100">
      <span class="text-sm">🤖</span>
    </div>
    <div class="rounded-2xl rounded-tl-sm bg-slate-100 px-4 py-3 flex items-center gap-1.5">
      <span class="ai-thinking-dot"></span>
      <span class="ai-thinking-dot"></span>
      <span class="ai-thinking-dot"></span>
    </div>`;
  container.appendChild(wrapper);
  container.scrollTop = container.scrollHeight;
}

function removeThinkingIndicator() {
  const el = document.getElementById('ai-thinking');
  if (el) el.remove();
}

function addSourceLinks(sources) {
  if (!sources || sources.length === 0) return;
  const container = document.getElementById('ai-chat-messages');
  const wrapper = document.createElement('div');
  wrapper.className = 'flex gap-3 ai-msg-animate';
  const links = sources.map(s =>
    `<a href="/docs/${s.id}" target="_blank" class="inline-flex items-center gap-1 rounded-lg border border-indigo-200 bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-600 transition-all hover:bg-indigo-100 no-underline">
      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      ${escapeHtmlChat(s.title)}
    </a>`
  ).join('');

  wrapper.innerHTML = `
    <div class="w-8 shrink-0"></div>
    <div class="flex flex-wrap gap-1.5">${links}</div>`;
  container.appendChild(wrapper);
  container.scrollTop = container.scrollHeight;
}

async function sendAiChat(e) {
  e.preventDefault();
  const input = document.getElementById('ai-chat-input');
  const sendBtn = document.getElementById('ai-chat-send');
  const question = input.value.trim();
  if (!question) return;

  // Add user message
  addChatMessage('user', question);
  input.value = '';
  input.disabled = true;
  sendBtn.disabled = true;

  // Show thinking
  addThinkingIndicator();

  try {
    const resp = await fetch('/api/ai/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ question })
    });
    const data = await resp.json();
    removeThinkingIndicator();

    if (!resp.ok) {
      addChatMessage('ai', '⚠️ ' + (data.error || 'Lỗi không xác định'));
    } else {
      addChatMessage('ai', data.answer);
      addSourceLinks(data.sources);
    }
  } catch (err) {
    removeThinkingIndicator();
    addChatMessage('ai', '⚠️ Lỗi kết nối: ' + err.message);
  }

  input.disabled = false;
  sendBtn.disabled = false;
  input.focus();
}

function escapeHtmlChat(str) {
  const d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}

function formatAiAnswer(text) {
  // Convert newlines to <br> and preserve basic formatting
  return escapeHtmlChat(text).replace(/\n/g, '<br>');
}

window.__aiGlobalSessionId = null;
async function playGlobalTtSAudio(text, btnId) {
    if (!text || text.trim() === '') return;
    const currentSession = Date.now();
    window.__aiGlobalSessionId = currentSession;
    
    if (window.__currentCloudAudio) {
        window.__currentCloudAudio.pause();
        window.__currentCloudAudio = null;
    }
    window.__ttsQueue = [];
    
    let btnEl = document.getElementById(btnId);
    let originalHtml = '';
    if (btnEl) {
        originalHtml = btnEl.innerHTML;
        btnEl.innerHTML = `<span class="inline-flex gap-1 items-center"><span class="h-2 w-2 rounded-full bg-brand-500 animate-bounce" style="animation-delay:0ms"></span><span class="h-2 w-2 rounded-full bg-brand-500 animate-bounce" style="animation-delay:150ms"></span><span class="h-2 w-2 rounded-full bg-brand-500 animate-bounce" style="animation-delay:300ms"></span> Đang nạp...</span>`;
    }

    try {
        const resp = await fetch('/api/ai/tts', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text })
        });
        
        if (!resp.ok) throw new Error("TTS Err");
        
        const data = await resp.json();
        
        if (window.__aiGlobalSessionId !== currentSession) return;
        if (btnEl) btnEl.innerHTML = originalHtml;
        
        if (data.chunks && data.chunks.length > 0) {
            window.__ttsQueue = data.chunks;
            function playNextHandoff() {
                if (window.__aiGlobalSessionId !== currentSession) return;
                if (window.__ttsQueue.length === 0) {
                    if (btnEl) btnEl.classList.remove('opacity-50');
                    return;
                }
                if (btnEl) btnEl.classList.add('opacity-50');
                
                const base64Audio = window.__ttsQueue.shift();
                const audio = new Audio("data:audio/mp3;base64," + base64Audio);
                window.__currentCloudAudio = audio;
                
                audio.onended = playNextHandoff;
                audio.onerror = () => { playNextHandoff(); };
                audio.play().catch(e => console.log('Autoplay Error:', e));
            }
            playNextHandoff();
        }
    } catch (err) {
        if (btnEl) btnEl.innerHTML = originalHtml;
    }
}
</script>

<% } %>
